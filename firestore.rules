rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isParticipant(chatId) {
      return isAuthenticated() && (
        chatId == "ai_" + request.auth.uid ||
        (exists(/databases/$(database)/documents/chats/$(chatId)) && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants)
      );
    }

    // User profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);

      match /contacts/{contactId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Stories
    match /stories/{storyId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Chats
    match /chats/{chatId} {
      allow read: if isAuthenticated() && (resource == null || request.auth.uid in resource.data.participants || chatId == "ai_" + request.auth.uid);
      allow create: if isAuthenticated() && (request.auth.uid in request.resource.data.participants || chatId == "ai_" + request.auth.uid);
      allow update: if isAuthenticated() && (request.auth.uid in resource.data.participants || chatId == "ai_" + request.auth.uid);
      
      // Messages subcollection
      match /messages/{messageId} {
        allow read: if isParticipant(chatId);
        allow create: if isParticipant(chatId) && (request.resource.data.senderId == request.auth.uid || request.resource.data.senderId == 'ai-assistant');
        allow update: if isParticipant(chatId); // For reactions and seen status
      }
    }
  }
}
