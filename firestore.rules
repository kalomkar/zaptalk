rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net: Default deny everything
    match /{document=**} {
      allow read, write: if false;
    }

    // Public health check / connection verification
    match /system/{docId} {
      allow read: if true; // Publicly readable for status checks
    }

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isParticipant(chatId) {
      return isAuthenticated() && (
        chatId == "ai_" + request.auth.uid ||
        chatId.contains(request.auth.uid) ||
        (exists(/databases/$(database)/documents/chats/$(chatId)) && 
         request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants)
      );
    }

    // User profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);

      match /contacts/{contactId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Stories (WhatsApp Status)
    match /stories/{storyId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    // Private Chats
    match /chats/{chatId} {
      // Allow read if user is a participant or it's an AI chat
      // We also allow if the chat doc doesn't exist yet but user is the owner of the deterministic ID
      allow read, list: if isAuthenticated() && (
        chatId == "ai_" + request.auth.uid ||
        chatId.contains(request.auth.uid) ||
        (resource != null && request.auth.uid in resource.data.participants)
      );
      
      allow create: if isAuthenticated() && (
        chatId == "ai_" + request.auth.uid ||
        chatId.contains(request.auth.uid) ||
        request.auth.uid in request.resource.data.participants
      );
      
      allow update, delete: if isAuthenticated() && (
        chatId == "ai_" + request.auth.uid ||
        request.auth.uid in resource.data.participants
      );
      
      // Messages subcollection
      match /messages/{messageId} {
        allow read, list: if isParticipant(chatId);
        allow create: if isParticipant(chatId) && (
          request.resource.data.senderId == request.auth.uid || 
          request.resource.data.senderId == 'ai-assistant'
        );
        allow update: if isParticipant(chatId); // Shared for seen status/reactions
        allow delete: if isParticipant(chatId); // Allow participants to delete (clear) messages
      }
    }
  }
}
